# Supabase (required)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Production multi-domain (recommended for wakaschool.org split)
# Dev: omit these — the app uses the current browser origin on localhost.
VITE_APP_URL=https://app.wakaschool.org
VITE_PORTAL_URL=https://portal.wakaschool.org
VITE_MARKETING_URL=https://wakaschool.org

# Supabase Dashboard → Authentication → URL configuration must allow:
# - https://app.wakaschool.org/**
# - https://portal.wakaschool.org/**
# - http://localhost:5173/**
